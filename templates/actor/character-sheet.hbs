              </div>
            {{/each}}
          </div>
        {{else}}
          <p>{{localize "RIFTS.HandToHand.None"}}</p>
        {{/if}}
      </section>

      <section class="sheet-section">
        <h2>{{localize "RIFTS.Sheet.Details"}}</h2>
        <div class="grid details-grid">
          <div class="field">
            <label>{{localize "RIFTS.Sheet.SizeCategory"}}</label>
            <select name="system.details.sizeCategory">
              {{selectOptions sizeCategoryOptions selected=system.details.sizeCategory localize=false}}
            </select>
          </div>
          <div class="field">
            <label>{{localize "RIFTS.Sheet.ActorAR"}}</label>
            <input type="number" name="system.combat.ar" value="{{system.combat.ar}}">
          </div>
          {{#if canDebugLevelOverride}}
            <div class="field">
              <label>{{localize "RIFTS.Progression.OverrideLevel"}}</label>
              <input type="checkbox" name="system.debug.useLevelOverride" {{#if useLevelOverride}}checked{{/if}}>
            </div>
            <div class="field">
              <label>{{localize "RIFTS.Progression.Level"}}</label>
              <input type="number" min="1" name="system.debug.overrideLevel" value="{{overrideLevel}}">
            </div>
          {{/if}}
        </div>
      </section>

      {{#if canRecoveryControls}}
        <section class="sheet-section">
          <h2>{{localize "RIFTS.Recovery.Controls"}}</h2>
          <div class="item-actions">
            <button type="button" data-action="gm-short-rest">{{localize "RIFTS.Recovery.ShortRest"}}</button>
            <button type="button" data-action="gm-full-rest">{{localize "RIFTS.Recovery.FullRest"}}</button>
            <button type="button" data-action="gm-repair-armor">{{localize "RIFTS.Recovery.RepairArmor"}}</button>
            <button type="button" data-action="gm-reset-apm-sheet">{{localize "RIFTS.Combat.ResetAPM"}}</button>
            <button type="button" data-action="gm-add-apm-sheet">{{localize "RIFTS.Combat.AddAPM"}}</button>
          </div>
          <p class="help-text">{{localize "RIFTS.Recovery.GMOnlyHint"}}</p>
        </section>
      {{/if}}
    </aside>
  </div>
</form>

























