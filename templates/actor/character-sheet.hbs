<form class="rifts-sheet">
  <header class="sheet-header rifts-header">
    <div class="header-portrait-wrap">
      <img class="header-portrait" src="{{portraitImg}}" alt="{{actor.name}}" title="Double-click to set portrait">
    </div>

    <div class="header-main">
      <input class="header-name" type="text" name="name" value="{{actor.name}}">
      <div class="header-meta progression-meta">
        <label>{{localize "RIFTS.Progression.Level"}}</label>
        <strong>{{derivedLevel}}</strong>
        <label>{{localize "RIFTS.Progression.XP"}}</label>
        <input type="number" min="0" name="system.details.experience" value="{{currentXP}}">
        <label>{{localize "RIFTS.Sheet.Alignment"}}</label>
        <select name="system.details.alignment">
          {{selectOptions alignmentOptions selected=system.details.alignment localize=false blank=alignmentBlankLabel}}
        </select>
        <span>
          {{#if hasNextLevelXP}}
            {{localize "RIFTS.Progression.NextLevel"}}: {{nextLevelXP}}
          {{else}}
            {{localize "RIFTS.Progression.NextLevel"}}: -
          {{/if}}
        </span>
        <button type="button" data-action="roll-initiative">{{localize "RIFTS.Rolls.Initiative"}}</button>
        {{#if hasCombat}}
          <button type="button" data-action="roll-initiative-combat">{{localize "RIFTS.Rolls.InitiativeCombat"}}</button>
        {{/if}}
      </div>
      <div class="xp-progress-wrap">
        <label>{{localize "RIFTS.Progression.Progress"}}: {{xpProgressLabel}}</label>
        <div class="xp-progress-bar">
          <div class="xp-progress-fill" style="{{xpProgressBarStyle}}"></div>
        </div>
      </div>
    </div>

    <div class="sheet-lock-controls">
      {{#if canToggleLock}}
        <button type="button" data-action="toggle-lock" class="lock-toggle-btn">
          {{#if isLocked}}
            {{localize "RIFTS.Sheet.Unlock"}}
          {{else}}
            {{localize "RIFTS.Sheet.Lock"}}
          {{/if}}
        </button>
      {{else}}
        {{#if isLocked}}
          <span class="sheet-locked-pill">{{localize "RIFTS.Sheet.Locked"}}</span>
        {{/if}}
      {{/if}}
    </div>
  </header>

  {{#if isLockedForUser}}
    <p class="sheet-lock-note">{{localize "RIFTS.Sheet.LockedNotice"}}</p>
  {{/if}}

  <div class="rifts-layout">
    <aside class="rifts-left">
      <section class="sheet-section">
        <h2>{{localize "RIFTS.Sheet.Attributes"}}</h2>
        <div class="grid attributes-grid">
          {{#each attributes as |key|}}
            <div class="field">
              <label for="attr-{{key}}"><span class="label-key">{{key}}</span></label>
              <div class="field-row">
                <input id="attr-{{key}}" type="number" name="system.attributes.{{key}}.value" value="{{lookup (lookup ../system.attributes key) "value"}}">
                <input type="number" name="system.attributes.{{key}}.mod" value="{{lookup (lookup ../system.attributes key) "mod"}}" title="{{localize 'RIFTS.Sheet.Mod'}}">
                <button type="button" data-action="roll-attribute" data-attribute-key="{{key}}">3d6</button>
              </div>
            </div>
          {{/each}}
        </div>
      </section>

      <section class="sheet-section">
        <h2>{{localize "RIFTS.Sheet.Resources"}}</h2>
        <div class="grid resources-grid">
          {{#each leftResources as |key|}}
            <div class="field">
              <label><span class="label-key">{{key}}</span></label>
              <div class="field-row">
                <input type="number" name="system.resources.{{key}}.value" value="{{lookup (lookup ../system.resources key) "value"}}">
                <span>/</span>
                <input type="number" name="system.resources.{{key}}.max" value="{{lookup (lookup ../system.resources key) "max"}}">
              </div>
            </div>
          {{/each}}
        </div>
      </section>

      <section class="sheet-section">
        <h2>{{localize "RIFTS.Sheet.DerivedCombat"}}</h2>
        <div class="derived-combat-grid">
          <div class="derived-cell">
            <span>{{localize "RIFTS.Sheet.StrikeTotal"}}</span>
            <strong>{{system.combat.derived.strikeTotal}}</strong>
          </div>
          <div class="derived-cell">
            <span>{{localize "RIFTS.Sheet.ParryTotal"}}</span>
            <strong>{{system.combat.derived.parryTotal}}</strong>
          </div>
          <div class="derived-cell">
            <span>{{localize "RIFTS.Sheet.DodgeTotal"}}</span>
            <strong>{{system.combat.derived.dodgeTotal}}</strong>
          </div>
          <div class="derived-cell">
            <span>{{localize "RIFTS.Sheet.InitiativeTotal"}}</span>
            <strong>{{system.combat.derived.initiativeTotal}}</strong>
          </div>
        </div>
      </section>
      <section class="sheet-section active-class-panel">
            <h2>{{localize "RIFTS.Sheet.ActiveClass"}}</h2>


            {{#if hasLevelUpClass}}
              <div class="item-actions">
                <button type="button" data-action="open-level-up" {{#unless hasLevelUpClass}}disabled{{/unless}}>{{localize "RIFTS.LevelUp.LevelUp"}}</button>
              </div>
<div class="class-summary">
                <div><span>{{localize "RIFTS.Sheet.ActiveOCC"}}</span><strong>{{activeOccName}}</strong></div>
                <div><span>{{localize "RIFTS.Sheet.ActiveRCC"}}</span><strong>{{activeRccName}}</strong></div>
                <div><span>{{localize "RIFTS.Sheet.OCCSummary"}}</span><strong>{{occPassiveEffectsSummary}}</strong></div>
                <div><span>{{localize "RIFTS.Sheet.RCCSummary"}}</span><strong>{{rccPassiveEffectsSummary}}</strong></div>
                <div><span>{{localize "RIFTS.Sheet.PassiveEffects"}}</span><strong>{{classPassiveEffectsSummary}}</strong></div>
                <div><span>{{localize "RIFTS.Sheet.GrantedAbilities"}}</span><strong>{{classGrantedAbilitiesLabel}}</strong></div>
                <div><span>{{localize "RIFTS.Progression.Level"}}</span><strong>{{derivedLevel}}</strong></div>
                <div><span>{{localize "RIFTS.Sheet.AttacksPerMelee"}}</span><strong>{{attacksPerMelee}}</strong></div>
                <div><span>{{localize "RIFTS.Progression.ClassXP"}}</span><strong>{{activeClassExperience}}</strong></div>
                <div><span>{{localize "RIFTS.LevelUp.PendingChoices"}}</span><strong>{{levelUpPendingChoices}}</strong></div>
                <div><span>{{localize "RIFTS.LevelUp.RequiredChoices"}}</span><strong>{{levelUpRequiredProgress}}</strong></div>
                <div><span>{{localize "RIFTS.LevelUp.Status"}}</span><strong>{{levelUpStatusLabel}}</strong></div>
                <div><span>{{localize "RIFTS.Sheet.CombatBonuses"}}</span><strong>{{activeOccBonusesSummary}}</strong></div>
              </div>
<section class="sheet-section">
                <h3>{{localize "RIFTS.Sheet.OCCSummary"}}</h3>
                <div class="class-summary">
                  <div><span>{{localize "RIFTS.Sheet.AttributeRequirements"}}</span><strong>{{occRequirementsStatusLabel}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.RequirementsNotMet"}}</span><strong>{{occRequirementsSummary}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.SkillSelection"}}</span><strong>{{localize "RIFTS.Skills.OccSkill"}}: {{occSkillSelection.occ}}, {{localize "RIFTS.Sheet.SkillSelectionOccRelated"}}: {{occSkillSelection.related}}, {{localize "RIFTS.Skills.SecondarySkill"}}: {{occSkillSelection.secondary}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.OccSkillProgression"}}</span><strong>{{occSkillProgressionSummary.occ}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.OccRelatedProgression"}}</span><strong>{{occSkillProgressionSummary.related}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.SecondarySkillProgression"}}</span><strong>{{occSkillProgressionSummary.secondary}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.StartingResources"}}</span><strong>HP {{occStartingResources.hp}}, SDC {{occStartingResources.sdc}}, ISP {{occStartingResources.isp}}, PPE {{occStartingResources.ppe}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.ResourceProgression"}}</span><strong>HP {{#if occResourceProgression.hpPerLevel}}{{occResourceProgression.hpPerLevel}}{{else}}-{{/if}}, SDC {{#if occResourceProgression.sdcPerLevel}}{{occResourceProgression.sdcPerLevel}}{{else}}-{{/if}}, ISP {{#if occResourceProgression.ispPerLevel}}{{occResourceProgression.ispPerLevel}}{{else}}-{{/if}}, PPE {{#if occResourceProgression.ppePerLevel}}{{occResourceProgression.ppePerLevel}}{{else}}-{{/if}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.StartingPowers"}}</span><strong>{{localize "RIFTS.Powers.Spell"}}: {{occStartingSpellsCount}}, {{localize "RIFTS.Powers.Psionic"}}: {{occStartingPsionicsCount}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.SpellProgression"}}</span><strong>{{occSpellProgressionSummary}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.PsionicProgression"}}</span><strong>{{occPsionicProgressionSummary}}</strong></div>
                  <div><span>{{localize "RIFTS.Sheet.StartingCredits"}}</span><strong>{{occStartingCredits.credits}}</strong></div>
                </div>
{{#if hasOccAttributeRequirements}}
                  <div class="item-list">
                    <div class="item-row class-skill-row item-header">
                      <span>{{localize "RIFTS.Item.Name"}}</span>
                      <span>{{localize "RIFTS.Sheet.AttributeRequirements"}}</span>
                      <span>{{localize "RIFTS.Rolls.Total"}}</span>
                      <span>{{localize "RIFTS.Sheet.Status"}}</span>
                    </div>
                    {{#each occAttributeRequirementRows as |entry|}}
                      {{#if entry.hasRequirement}}
                        <div class="item-row class-skill-row">
                          <span>{{entry.label}}</span>
                          <span>{{entry.required}}</span>
                          <span>{{entry.actual}}</span>
                          <span>{{#if entry.met}}{{localize "RIFTS.Sheet.RequirementsMet"}}{{else}}{{localize "RIFTS.Sheet.RequirementsNotMet"}}{{/if}}</span>
                        </div>
                      {{/if}}
                    {{/each}}
                  </div>
                {{else}}
                  <p>{{localize "RIFTS.Sheet.None"}}</p>
                {{/if}}
              </section>

<section class="sheet-section">
                <h3>{{localize "RIFTS.Augmentation.StartingPackage"}}</h3>
                <p><strong>{{localize "RIFTS.Sheet.ActiveOCC"}}:</strong> {{#if occAugmentationPackageName}}{{occAugmentationPackageName}}{{else}}{{localize "RIFTS.Sheet.NoActiveOCC"}}{{/if}}</p>
                {{#if hasOccAugmentationPackage}}
                  {{#if hasOccPackageBionics}}
                    <h4>{{localize "RIFTS.Augmentation.Bionics"}}</h4>
                    <div class="item-list">
                      <div class="item-row class-package-row item-header">
                        <span>{{localize "RIFTS.Item.Name"}}</span>
                        <span>{{localize "RIFTS.Augmentation.Slot"}}</span>
                        <span>{{localize "RIFTS.Augmentation.Effects"}}</span>
                        <span>{{localize "RIFTS.Sheet.Action"}}</span>
                      </div>
                      {{#each occPackageBionics as |entry|}}
                        <div class="item-row class-package-row">
                          <span>{{entry.name}}</span>
                          <span>{{#if entry.slot}}{{entry.slot}}{{else}}{{localize "RIFTS.Sheet.None"}}{{/if}}</span>
                          <span>{{#if entry.effectsSummary}}{{entry.effectsSummary}}{{else}}{{localize "RIFTS.Sheet.None"}}{{/if}}</span>
                          <span>
                            {{#if entry.isAdded}}
                              {{localize "RIFTS.Augmentation.AlreadyInstalled"}}
                            {{else}}
                              <button type="button" data-action="add-occ-package-item" data-package-type="{{entry.packageType}}" data-package-index="{{entry.packageIndex}}">{{localize "RIFTS.Augmentation.AddPackageItem"}}</button>
                            {{/if}}
                          </span>
                        </div>
                      {{/each}}
                    </div>
                  {{/if}}

                  {{#if hasOccPackageCybernetics}}
                    <h4>{{localize "RIFTS.Augmentation.Cybernetics"}}</h4>
                    <div class="item-list">
                      <div class="item-row class-package-row item-header">
                        <span>{{localize "RIFTS.Item.Name"}}</span>
                        <span>{{localize "RIFTS.Augmentation.Slot"}}</span>
                        <span>{{localize "RIFTS.Augmentation.Effects"}}</span>
                        <span>{{localize "RIFTS.Sheet.Action"}}</span>
                      </div>
                      {{#each occPackageCybernetics as |entry|}}
                        <div class="item-row class-package-row">
                          <span>{{entry.name}}</span>
                          <span>{{#if entry.slot}}{{entry.slot}}{{else}}{{localize "RIFTS.Sheet.None"}}{{/if}}</span>
                          <span>{{#if entry.effectsSummary}}{{entry.effectsSummary}}{{else}}{{localize "RIFTS.Sheet.None"}}{{/if}}</span>
                          <span>
                            {{#if entry.isAdded}}
                              {{localize "RIFTS.Augmentation.AlreadyInstalled"}}
                            {{else}}
                              <button type="button" data-action="add-occ-package-item" data-package-type="{{entry.packageType}}" data-package-index="{{entry.packageIndex}}">{{localize "RIFTS.Augmentation.AddPackageItem"}}</button>
                            {{/if}}
                          </span>
                        </div>
                      {{/each}}
                    </div>
                  {{/if}}
                {{else}}
                  <p>{{localize "RIFTS.Augmentation.NoPackageItems"}}</p>
                {{/if}}
              </section>

              <div class="class-overview-scroll">

              <div class="item-list">
                <div class="item-row class-overview-row item-header">
                  <span>{{localize "RIFTS.Item.Name"}}</span>
                  <span>{{localize "RIFTS.Sheet.ClassType"}}</span>
                  <span>{{localize "RIFTS.Item.Category"}}</span>
                  <span>{{localize "RIFTS.Progression.ClassXP"}}</span>
                  <span>{{localize "RIFTS.Sheet.PassiveEffects"}}</span>
                  <span>{{localize "RIFTS.Sheet.GrantedAbilities"}}</span>
                  <span>{{localize "RIFTS.Sheet.Primary"}}</span>
                  <span>{{localize "RIFTS.Sheet.Manage"}}</span>
                </div>
                {{#each classItems as |entry|}}
                  <div class="item-row class-overview-row inventory-item-row" data-item-id="{{entry.item.id}}">
                    <span>{{entry.item.name}}</span>
                    <span>{{entry.data.typeLabel}}</span>
                    <span>{{entry.data.category}}</span>
                    <span>{{entry.data.classXP}}</span>
                    <span>{{#if entry.data.effectsSummary}}{{entry.data.effectsSummary}}{{else}}{{localize "RIFTS.Sheet.None"}}{{/if}}</span>
                    <span>{{entry.data.grantedAbilitiesCount}}</span>
                    <span>{{#if entry.data.isActive}}{{localize "RIFTS.Sheet.Primary"}}{{else}}-{{/if}}</span>
                    <span class="item-actions">
                      {{#if entry.data.isActive}}
                        <span>{{localize "RIFTS.Sheet.Primary"}}</span>
                      {{else}}
                        <button type="button" data-action="set-primary-class" data-item-id="{{entry.item.id}}">{{localize "RIFTS.Sheet.SetPrimary"}}</button>
                      {{/if}}
                      <button type="button" data-action="edit-item" data-item-id="{{entry.item.id}}">{{localize "RIFTS.Sheet.Edit"}}</button>
                      <button type="button" data-action="delete-item" data-item-id="{{entry.item.id}}">{{localize "RIFTS.Sheet.Delete"}}</button>
                    </span>
                  </div>
                {{/each}}
              </div>
              </div>
            {{else}}
              <div class="item-actions">
                <button type="button" data-action="open-character-creation">{{localize "RIFTS.Creation.BeginCharacter"}}</button>
              </div>
              <p>{{localize "RIFTS.Sheet.NoActiveClass"}}</p>
            {{/if}}
          </section>
        

    </aside>

    <main class="rifts-center">
      <nav class="sheet-tabs" aria-label="{{localize 'RIFTS.Sheet.Tabs'}}">
        <button type="button" data-action="switch-tab" data-tab="combat" class="tab-btn {{#if isCombatTab}}active{{/if}}">{{localize "RIFTS.Sheet.Combat"}}</button>
        <button type="button" data-action="switch-tab" data-tab="skills" class="tab-btn {{#if isSkillsTab}}active{{/if}}">{{localize "RIFTS.Sheet.Skills"}}</button>
        <button type="button" data-action="switch-tab" data-tab="inventory" class="tab-btn {{#if isInventoryTab}}active{{/if}}">{{localize "RIFTS.Sheet.Inventory"}}</button>
        <button type="button" data-action="switch-tab" data-tab="powers" class="tab-btn {{#if isPowersTab}}active{{/if}}">{{localize "RIFTS.Sheet.Powers"}}</button>
        <button type="button" data-action="switch-tab" data-tab="notes" class="tab-btn {{#if isNotesTab}}active{{/if}}">{{localize "RIFTS.Sheet.Notes"}}</button>
      </nav>

      <section class="tab-panel {{#if isCombatTab}}active{{/if}}">
        {{#if isCombatTab}}
          <section class="sheet-section">
            <h2>{{localize "RIFTS.Sheet.Targeting"}}</h2>
            <div class="targeting-row">
              <span>{{localize "RIFTS.Sheet.CurrentTarget"}}: <strong>{{currentTargetName}}</strong></span>
              <span>{{localize "RIFTS.Sheet.SavedTarget"}}: <strong>{{savedTargetName}}</strong></span>
              <button type="button" data-action="use-current-target">{{localize "RIFTS.Sheet.UseCurrentTarget"}}</button>
            </div>
          </section>

          <section class="sheet-section">
            <h2>{{localize "RIFTS.Melee.Queue"}}</h2>
            {{#if hasMeleeQueue}}
              <div class="melee-queue-row">
                <span><strong>{{localize "RIFTS.Melee.CurrentMeleeAction"}}:</strong> {{currentMeleeActorName}}</span>
                <span><strong>{{localize "RIFTS.Melee.QueuePosition"}}:</strong> {{meleeQueuePosition}}</span>
                <span><strong>{{localize "RIFTS.Melee.QueueLength"}}:</strong> {{meleeQueueLength}}</span>
                <span><strong>{{localize "RIFTS.Melee.Pass"}}:</strong> {{currentMeleePass}}</span>
              </div>
              {{#if isCurrentMeleeActor}}
                <p class="melee-state-active">{{localize "RIFTS.Melee.ActiveNow"}}</p>
              {{/if}}
              {{#if isWaitingForMeleeTurn}}
                <p class="melee-state-waiting">{{localize "RIFTS.Melee.WaitingForTurn"}}</p>
              {{/if}}
            {{else}}
              <p>{{localize "RIFTS.Melee.NoQueue"}}</p>
            {{/if}}

            <div class="held-action-row">
              <span><strong>{{localize "RIFTS.Advanced.HoldAction"}}:</strong> {{heldActionCount}}</span>
              <span><strong>{{localize "RIFTS.Advanced.ReleaseHeldAction"}}:</strong> {{#if heldActionReady}}{{localize "RIFTS.Melee.ActiveNow"}}{{else}}{{localize "RIFTS.Melee.WaitingForTurn"}}{{/if}}</span>
              <button type="button" data-action="hold-action">{{localize "RIFTS.Advanced.HoldAction"}}</button>
              <button type="button" data-action="release-held-action">{{localize "RIFTS.Advanced.ReleaseHeldAction"}}</button>
            </div>

            {{#if canAdvanceMelee}}
              <button type="button" data-action="advance-melee">{{localize "RIFTS.Melee.AdvanceQueue"}}</button>
            {{/if}}
          </section>

          <section class="sheet-section">
            <h2>{{localize "RIFTS.Sheet.Combat"}}</h2>
            <div class="combat-row">
              <label>{{localize "RIFTS.Rolls.Strike"}}</label>
              <input type="number" name="system.combat.strikeMod" value="{{system.combat.strikeMod}}">
              <button type="button" data-action="roll-strike">d20</button>
            </div>
            <div class="combat-row">
              <label>{{localize "RIFTS.Rolls.Parry"}}</label>
              <input type="number" name="system.combat.parryMod" value="{{system.combat.parryMod}}">
              <button type="button" data-action="roll-parry">d20</button>
            </div>
            <div class="combat-row">
              <label>{{localize "RIFTS.Rolls.Dodge"}}</label>
              <input type="number" name="system.combat.dodgeMod" value="{{system.combat.dodgeMod}}">
              <button type="button" data-action="roll-dodge">d20</button>
            </div>
            <div class="combat-row">
              <label>{{localize "RIFTS.Rolls.Initiative"}}</label>
              <input type="number" name="system.combat.initiativeMod" value="{{system.combat.initiativeMod}}">
              <button type="button" data-action="roll-initiative">d20</button>
            </div>
            <div class="combat-row">
              <label>{{localize "RIFTS.Sheet.ActorAR"}}</label>
              <input type="number" name="system.combat.ar" value="{{system.combat.ar}}">
              <span>{{localize "RIFTS.Sheet.EquippedArmor"}}: <strong>{{equippedArmorName}}</strong></span>
            </div>
            <div class="combat-row">
              <label>{{localize "RIFTS.Sheet.Durability"}}</label>
              <span><strong>{{effectiveDurabilityLabel}}</strong></span>
              <span></span>
            </div>
            <div class="combat-row">
              <label>{{localize "RIFTS.Advanced.AutoDodge"}}</label>
              <span><strong>{{autoDodgeStatusLabel}}</strong></span>
              <span>{{localize "RIFTS.HandToHand.AutoDodgeLevel"}}: {{#if activeHandToHandBonuses.autoDodgeLevel}}{{activeHandToHandBonuses.autoDodgeLevel}}{{else}}-{{/if}}</span>
            </div>
          </section>

          <nav class="sheet-tabs combat-subtabs" aria-label="{{localize 'RIFTS.Sheet.Combat'}}">
            <button type="button" data-action="switch-combat-subtab" data-subtab="unarmed" class="tab-btn {{#if isCombatSubtabUnarmed}}active{{/if}}">{{localize "RIFTS.Sheet.UnarmedAndManeuvers"}}</button>
            <button type="button" data-action="switch-combat-subtab" data-subtab="weapons" class="tab-btn {{#if isCombatSubtabWeapons}}active{{/if}}">{{localize "RIFTS.Sheet.Weapons"}}</button>
            <button type="button" data-action="switch-combat-subtab" data-subtab="armor" class="tab-btn {{#if isCombatSubtabArmor}}active{{/if}}">{{localize "RIFTS.Sheet.Armor"}}</button>
          </nav>

          <section class="combat-subtab-section {{#if isCombatSubtabUnarmed}}active{{/if}}" data-combat-subtab-section="unarmed">
          <section class="sheet-section">
            <h2>{{localize "RIFTS.Unarmed.Combat"}}</h2>
            {{#if hasUnarmedManeuvers}}
              <div class="item-list">
                <div class="item-row weapons-row item-header">
                  <span>{{localize "RIFTS.Unarmed.Strike"}}</span>
                  <span>{{localize "RIFTS.Item.Damage"}}</span>
                  <span>{{localize "RIFTS.Unarmed.StrengthBonus"}}</span>
                  <span>{{localize "RIFTS.HandToHand.DamageBonus"}}</span>
                  <span>{{localize "RIFTS.Sheet.Action"}}</span>
                </div>
                {{#each unarmedManeuvers as |maneuver|}}
                  <div class="item-row weapons-row">
                    <span>{{maneuver.label}}</span>
                    <span>{{maneuver.damageFormula}}</span>
                    <span>{{maneuver.strengthBonus}}</span>
                    <span>{{maneuver.handToHandBonus}}</span>
                    <span class="item-actions">
                      <button type="button" data-action="unarmed-attack" data-maneuver-key="{{maneuver.key}}" {{#unless ../canUseUnarmedManeuver}}disabled{{/unless}}>{{localize "RIFTS.Combat.Attack"}}</button>
                    </span>
                  </div>
                  {{#if maneuver.specialRules}}
                    <p class="help-text">{{maneuver.specialRules}}</p>
                  {{/if}}
                {{/each}}
              </div>
            {{else}}
              <p>{{localize "RIFTS.Advanced.NotAvailable"}}</p>
            {{/if}}
          </section>

          <section class="sheet-section">
            <h2>{{localize "RIFTS.Maneuvers.SpecialManeuvers"}}</h2>
            <p><strong>{{localize "RIFTS.HandToHand.ActiveStyle"}}:</strong> {{#if activeHthStyleManeuverName}}{{activeHthStyleManeuverName}}{{else}}{{localize "RIFTS.HandToHand.None"}}{{/if}}</p>
            <div class="available-pools">
              <button type="button" data-action="open-available-maneuvers">{{localize "RIFTS.SelectionDialog.AvailableManeuvers"}}</button>
            </div>
            <div class="item-list">
              <div class="item-row weapons-row item-header">
                <span>{{localize "RIFTS.Item.Name"}}</span>
                <span>{{localize "RIFTS.Item.Category"}}</span>
                <span>{{localize "RIFTS.Maneuvers.ActionCost"}}</span>
                <span>{{localize "RIFTS.Maneuvers.MinLevel"}}</span>
                <span>{{localize "RIFTS.Sheet.Action"}}</span>
                <span>{{localize "RIFTS.Sheet.Manage"}}</span>
              </div>
              {{#if hasSpecialManeuvers}}
                {{#each specialManeuvers as |entry|}}
                  <div class="item-row weapons-row inventory-item-row" data-item-id="{{entry.item.id}}">
                    <span>{{entry.item.name}}</span>
                    <span>{{entry.data.categoryLabel}}</span>
                    <span>{{entry.data.actionCost}}</span>
                    <span>{{entry.data.minLevel}}</span>
                    <span class="item-actions">
                      <button type="button" data-action="use-special-maneuver" data-item-id="{{entry.item.id}}">{{localize "RIFTS.Combat.Attack"}}</button>
                    </span>
                    <span class="item-actions">
