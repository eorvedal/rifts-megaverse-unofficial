<form class="rifts-item-sheet">
  <header class="sheet-header">
    <h1>{{localize "RIFTS.Sheet.Item"}}: {{itemType}}</h1>
  </header>

  <section class="sheet-section">
    <label for="item-name">{{localize "RIFTS.Item.Name"}}</label>
    <input id="item-name" type="text" name="name" value="{{item.name}}">
  </section>

  {{#if isSkill}}
    <section class="sheet-section two-col">
      <div>
        <label>{{localize "RIFTS.Item.Category"}}</label>
        <input type="text" name="system.category" value="{{system.category}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Sheet.SkillBase"}}</label>
        <input type="number" name="system.base" value="{{system.base}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Sheet.SkillPerLevel"}}</label>
        <input type="number" name="system.perLevel" value="{{system.perLevel}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Sheet.SkillModifier"}}</label>
        <input type="number" name="system.modifier" value="{{system.modifier}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Skills.OccSkill"}}</label>
        <input type="checkbox" name="system.isOCCSkill" {{#if system.isOCCSkill}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Skills.RelatedSkill"}}</label>
        <input type="checkbox" name="system.isRelatedSkill" {{#if system.isRelatedSkill}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Skills.SecondarySkill"}}</label>
        <input type="checkbox" name="system.isSecondarySkill" {{#if system.isSecondarySkill}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Skills.Source"}}</label>
        <input type="text" name="system.sourceType" value="{{system.sourceType}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Skills.SourceId"}}</label>
        <input type="text" name="system.sourceId" value="{{system.sourceId}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Skills.AutomationType"}}</label>
        <select name="system.automationType">
          {{selectOptions skillAutomationTypeOptions selected=system.automationType localize=false}}
        </select>
      </div>
    </section>

    <section class="sheet-section">
      <label>{{localize "RIFTS.Skills.PassiveEffects"}}</label>
      <textarea rows="8" data-action="skill-effects">{{skillEffectsText}}</textarea>
    </section>

    <section class="sheet-section">
      <label>{{localize "RIFTS.Skills.RollableEffects"}}</label>
      <textarea rows="8" data-action="skill-rollable-effects">{{skillRollableEffectsText}}</textarea>
      {{#if skillHasRollableEffects}}
        <label>{{localize "RIFTS.Skills.ResolvedEffects"}}</label>
        <textarea rows="6" readonly>{{skillResolvedEffectsText}}</textarea>
      {{/if}}
    </section>

    {{#if isSkillAutomationPhysical}}
      <section class="sheet-section two-col">
        <div>
          <label>{{localize "RIFTS.Skills.RollWithPunchBonus"}}</label>
          <input type="number" data-action="skill-physical-rules" data-rule-key="rollWithPunchBonus" value="{{skillPhysicalRules.rollWithPunchBonus}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.ClimbBonus"}}</label>
          <input type="number" data-action="skill-physical-rules" data-rule-key="climbBonus" value="{{skillPhysicalRules.climbBonus}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.ClimbBaseGrant"}}</label>
          <input type="number" data-action="skill-physical-rules" data-rule-key="climbBaseGrant" value="{{skillPhysicalRules.climbBaseGrant}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.ProwlBonus"}}</label>
          <input type="number" data-action="skill-physical-rules" data-rule-key="prowlBonus" value="{{skillPhysicalRules.prowlBonus}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.ProwlBaseGrant"}}</label>
          <input type="number" data-action="skill-physical-rules" data-rule-key="prowlBaseGrant" value="{{skillPhysicalRules.prowlBaseGrant}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.KickAttackUnlock"}}</label>
          <input type="checkbox" data-action="skill-physical-rules" data-rule-key="kickAttack" {{#if skillPhysicalRules.kickAttack}}checked{{/if}}>
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.KickDamageFormula"}}</label>
          <input type="text" data-action="skill-physical-rules" data-rule-key="kickDamageFormula" value="{{skillPhysicalRules.kickDamageFormula}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.CrushSqueezeUnlock"}}</label>
          <input type="checkbox" data-action="skill-physical-rules" data-rule-key="crushSqueeze" {{#if skillPhysicalRules.crushSqueeze}}checked{{/if}}>
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.AutomaticKnockoutOn20"}}</label>
          <input type="checkbox" data-action="skill-physical-rules" data-rule-key="automaticKnockoutOn20" {{#if skillPhysicalRules.automaticKnockoutOn20}}checked{{/if}}>
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.BodyBlockTackleDamage"}}</label>
          <input type="text" data-action="skill-physical-rules" data-rule-key="bodyBlockTackleDamage" value="{{skillPhysicalRules.bodyBlockTackleDamage}}">
        </div>
      </section>
    {{/if}}

    {{#if isSkillAutomationWeaponProficiency}}
      <section class="sheet-section two-col">
        <div>
          <label>{{localize "RIFTS.Skills.WeaponProficiencyKey"}}</label>
          <input type="text" data-action="skill-wp-key" value="{{skillWpData.proficiencyKey}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.WPClassification"}}</label>
          <select name="system.weaponProficiency.classification">
            {{selectOptions skillWpClassificationOptions selected=skillWpData.classification localize=false}}
          </select>
        </div>
        <div>
          <label>{{localize "RIFTS.Skills.WPAllowedParry"}}</label>
          <input type="checkbox" name="system.weaponProficiency.allowedParry" {{#if skillWpData.allowedParry}}checked{{/if}}>
        </div>
      </section>

      <section class="sheet-section">
        <label>{{localize "RIFTS.Skills.WPStrikeProgression"}}</label>
        <textarea rows="2" data-action="skill-wp-progression-array" data-progression-key="strikeProgression">{{skillWpStrikeProgressionText}}</textarea>
        <label>{{localize "RIFTS.Skills.WPParryProgression"}}</label>
        <textarea rows="2" data-action="skill-wp-progression-array" data-progression-key="parryProgression">{{skillWpParryProgressionText}}</textarea>
        <label>{{localize "RIFTS.Skills.WPThrownProgression"}}</label>
        <textarea rows="2" data-action="skill-wp-progression-array" data-progression-key="thrownProgression">{{skillWpThrownProgressionText}}</textarea>
        <label>{{localize "RIFTS.Skills.WPRangeProgression"}}</label>
        <textarea rows="2" data-action="skill-wp-progression-array" data-progression-key="rangeProgression">{{skillWpRangeProgressionText}}</textarea>
      </section>
    {{/if}}

    <section class="sheet-section">
      <label>{{localize "RIFTS.Item.Description"}}</label>
      <textarea name="system.description" rows="5">{{system.description}}</textarea>
    </section>

    <section class="sheet-section">
      <label>{{localize "RIFTS.Sheet.Notes"}}</label>
      <textarea name="system.notes" rows="4">{{system.notes}}</textarea>
    </section>

  {{/if}}

  {{#if isWeapon}}
    <section class="sheet-section two-col">
      <div>
        <label>{{localize "RIFTS.Item.Equipped"}}</label>
        <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Item.Active"}}</label>
        <input type="checkbox" name="system.active" {{#if system.active}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Item.Damage"}}</label>
        <input type="text" name="system.weapon.damage" value="{{system.weapon.damage}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.BonusStrike"}}</label>
        <input type="number" name="system.weapon.bonusStrike" value="{{system.weapon.bonusStrike}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.AttackType"}}</label>
        <input type="text" name="system.weapon.attackType" value="{{system.weapon.attackType}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.Range"}}</label>
        <input type="text" name="system.weapon.range" value="{{system.weapon.range}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Skills.WeaponProficiencyKey"}}</label>
        <input type="text" data-action="weapon-proficiency-key" value="{{system.weapon.proficiencyKey}}">
      </div>
      <div>
        <label title="Marks this weapon as mounted so it can be treated as a mounted system.">{{localize "RIFTS.Vehicle.IsMounted"}}</label>
        <input type="checkbox" name="system.weapon.isMounted" {{#if system.weapon.isMounted}}checked{{/if}}>
      </div>
      <div>
        <label title="Mount is a descriptive mount point label (for example, shoulder hardpoint).">{{localize "RIFTS.Vehicle.Mount"}}</label>
        <input type="text" name="system.weapon.mountName" value="{{system.weapon.mountName}}" title="Descriptive mount point label shown on sheets/chat.">
      </div>
      <div>
        <label title="Link this mounted weapon to a specific armor item (usually active power armor).">{{localize "RIFTS.PowerArmor.LinkedArmor"}}</label>
        {{#if hasLinkedArmorChoices}}
          <select name="system.weapon.linkedArmorId" title="Choose which owned armor this weapon is linked to.">
            {{selectOptions linkedArmorChoices selected=system.weapon.linkedArmorId localize=false}}
          </select>
        {{else}}
          <input type="text" name="system.weapon.linkedArmorId" value="{{system.weapon.linkedArmorId}}" title="Set the linked armor item id manually if needed.">
        {{/if}}
      </div>
      <p class="help-text">Mount is a display label for the hardpoint. Linked Armor controls which power armor this mounted weapon appears under.</p>
      <div>
        <label title="If enabled, this weapon is intended to be used while wearing power armor.">{{localize "RIFTS.PowerArmor.RequiresPowerArmor"}}</label>
        <input type="checkbox" name="system.weapon.requiresPowerArmor" {{#if system.weapon.requiresPowerArmor}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Vehicle.LinkedToVehicle"}}</label>
        <input type="checkbox" name="system.weapon.linkedToVehicle" {{#if system.weapon.linkedToVehicle}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Vehicle.RequiresCrew"}}</label>
        <input type="number" min="1" name="system.weapon.requiresCrew" value="{{system.weapon.requiresCrew}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.MegaDamage"}}</label>
        <input type="checkbox" name="system.weapon.isMegaDamage" {{#if system.weapon.isMegaDamage}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.BurstFire"}}</label>
        <input type="checkbox" name="system.weapon.isBurstCapable" {{#if system.weapon.isBurstCapable}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.FireMode"}}</label>
        <input type="text" name="system.weapon.fireMode" value="{{system.weapon.fireMode}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.BurstSize"}}</label>
        <input type="number" min="1" name="system.weapon.burstSize" value="{{system.weapon.burstSize}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.BurstStrikeMod"}}</label>
        <input type="number" name="system.weapon.burstStrikeMod" value="{{system.weapon.burstStrikeMod}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.BurstDamageMultiplier"}}</label>
        <input type="number" min="1" name="system.weapon.burstDamageMultiplier" value="{{system.weapon.burstDamageMultiplier}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.BurstAmmoCost"}}</label>
        <input type="number" min="1" name="system.weapon.ammoPerBurst" value="{{system.weapon.ammoPerBurst}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.AimedShotModifier"}}</label>
        <input type="number" name="system.weapon.aimedStrikeMod" value="{{system.weapon.aimedStrikeMod}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Advanced.AimedShotCompatible"}}</label>
        <input type="checkbox" name="system.weapon.supportsAimedShot" {{#if system.weapon.supportsAimedShot}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Impact.Knockdown"}}</label>
        <input type="checkbox" name="system.weapon.canKnockdown" {{#if system.weapon.canKnockdown}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Impact.Knockback"}}</label>
        <input type="checkbox" name="system.weapon.canKnockback" {{#if system.weapon.canKnockback}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Impact.KnockbackValue"}}</label>
        <input type="number" min="0" name="system.weapon.knockbackValue" value="{{system.weapon.knockbackValue}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Impact.ImpactType"}}</label>
        <input type="text" name="system.weapon.impactType" value="{{system.weapon.impactType}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.AmmoCurrent"}}</label>
        <input type="number" name="system.weapon.ammo.value" value="{{system.weapon.ammo.value}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.AmmoMax"}}</label>
        <input type="number" name="system.weapon.ammo.max" value="{{system.weapon.ammo.max}}">
      </div>
    </section>
  {{/if}}

  {{#if isArmor}}
    <section class="sheet-section two-col">
      <div>
        <label>{{localize "RIFTS.Item.Equipped"}}</label>
        <input type="checkbox" name="system.equipped" {{#if system.equipped}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Item.Active"}}</label>
        <input type="checkbox" name="system.active" {{#if system.active}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Item.AR"}}</label>
        <input type="number" name="system.armor.ar" value="{{system.armor.ar}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.MegaDamageArmor"}}</label>
        <input type="checkbox" name="system.armor.isMegaDamageArmor" {{#if system.armor.isMegaDamageArmor}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.PowerArmor.IsPowerArmor"}}</label>
        <input type="checkbox" name="system.armor.isPowerArmor" {{#if system.armor.isPowerArmor}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.PowerArmor.Class"}}</label>
        <input type="text" name="system.armor.powerArmorClass" value="{{system.armor.powerArmorClass}}">
      </div>
      <div>
        <label>{{localize "RIFTS.PowerArmor.MountCapacity"}}</label>
        <input type="number" min="0" name="system.armor.mountCapacity" value="{{system.armor.mountCapacity}}">
      </div>
      <div>
        <label>{{localize "RIFTS.PowerArmor.HandlingMod"}}</label>
        <input type="number" name="system.armor.handlingMod" value="{{system.armor.handlingMod}}">
      </div>
      <div>
        <label>{{localize "RIFTS.PowerArmor.SpeedMod"}}</label>
        <input type="number" name="system.armor.speedMod" value="{{system.armor.speedMod}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.SdcCurrent"}}</label>
        <input type="number" name="system.armor.sdc.value" value="{{system.armor.sdc.value}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.SdcMax"}}</label>
        <input type="number" name="system.armor.sdc.max" value="{{system.armor.sdc.max}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.MdcCurrent"}}</label>
        <input type="number" name="system.armor.mdc.value" value="{{system.armor.mdc.value}}">
      </div>
      <div>
        <label>{{localize "RIFTS.Item.MdcMax"}}</label>
        <input type="number" name="system.armor.mdc.max" value="{{system.armor.mdc.max}}">
      </div>
    </section>

    <section class="sheet-section">
      <label>{{localize "RIFTS.PowerArmor.Notes"}}</label>
      <textarea name="system.armor.notes" rows="4">{{system.armor.notes}}</textarea>
    </section>
  {{/if}}


  {{#if isAugmentation}}
    <section class="sheet-section two-col">
      <div>
        <label>{{localize "RIFTS.Augmentation.Augmentation"}}</label>
        <input type="text" value="{{augmentationTypeLabel}}" disabled>
      </div>
      <div>
        <label>{{localize "RIFTS.Augmentation.Installed"}}</label>
        <input type="checkbox" name="system.installed" {{#if system.installed}}checked{{/if}}>
      </div>
      <div>
        <label>{{localize "RIFTS.Augmentation.Slot"}}</label>
        <input type="text" name="system.slot" value="{{system.slot}}">
      </div>
    </section>

    <section class="sheet-section">
      <label>{{localize "RIFTS.Augmentation.Effects"}} (JSON)</label>
      <textarea rows="10" data-action="augmentation-effects">{{augmentationEffectsText}}</textarea>
      <p class="help-text">{{localize "RIFTS.Augmentation.EffectsHelp"}}</p>
    </section>

    <section class="sheet-section">
      <label>{{localize "RIFTS.Augmentation.GrantedAbilities"}} (JSON Array)</label>
      <textarea rows="8" data-action="augmentation-granted-abilities">{{augmentationGrantedAbilitiesText}}</textarea>
      <p class="help-text">{{localize "RIFTS.Augmentation.GrantedAbilitiesHelp"}}</p>
    </section>

    <section class="sheet-section">
      <label>{{localize "RIFTS.Sheet.Notes"}}</label>
      <textarea name="system.notes" rows="5">{{system.notes}}</textarea>
    </section>
  {{/if}}
  {{#if isClassItem}}
    <section class="sheet-section">
      <h2>{{localize "RIFTS.Sheet.Overview"}}</h2>
      <div class="two-col">
        <div>
          <label>{{localize "RIFTS.Sheet.ClassType"}}</label>
          <input type="text" value="{{classLabel}}" disabled>
        </div>
        <div>
          <label>{{localize "RIFTS.Item.Category"}}</label>
          <input type="text" name="system.category" value="{{system.category}}">
        </div>
        <div>
          <label>{{localize "RIFTS.Sheet.Primary"}}</label>
          <input type="checkbox" name="system.isPrimaryClass" {{#if system.isPrimaryClass}}checked{{/if}}>
        </div>
        <div>
          <label>{{localize "RIFTS.Sheet.ActiveClass"}}</label>
          <input type="checkbox" name="system.active" {{#if system.active}}checked{{/if}}>
        </div>
      </div>
    </section>

    <section class="sheet-section">
      <h2>{{localize "RIFTS.Sheet.Requirements"}}</h2>
      <div class="two-col">
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (IQ)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="iq" value="{{classAttributeRequirements.iq}}"></div>
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (ME)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="me" value="{{classAttributeRequirements.me}}"></div>
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (MA)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="ma" value="{{classAttributeRequirements.ma}}"></div>
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (PS)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="ps" value="{{classAttributeRequirements.ps}}"></div>
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (PP)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="pp" value="{{classAttributeRequirements.pp}}"></div>
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (PE)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="pe" value="{{classAttributeRequirements.pe}}"></div>
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (PB)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="pb" value="{{classAttributeRequirements.pb}}"></div>
        <div><label>{{localize "RIFTS.Sheet.AttributeRequirements"}} (SPD)</label><input type="number" min="0" data-action="class-attribute-requirement" data-attribute-key="spd" value="{{classAttributeRequirements.spd}}"></div>
      </div>
    </section>

    <section class="sheet-section">
      <h2>{{localize "RIFTS.Sheet.Skills"}}</h2>
      <div class="two-col">
        <div><label>{{localize "RIFTS.Sheet.SkillSelection"}} ({{localize "RIFTS.Skills.OccSkill"}})</label><input type="number" min="0" name="system.skillSelection.occ" value="{{system.skillSelection.occ}}"></div>
        <div><label>{{localize "RIFTS.Sheet.SkillSelectionOccRelated"}}</label><input type="number" min="0" name="system.skillSelection.related" value="{{system.skillSelection.related}}"></div>
        <div><label>{{localize "RIFTS.Sheet.SkillSelection"}} ({{localize "RIFTS.Skills.SecondarySkill"}})</label><input type="number" min="0" name="system.skillSelection.secondary" value="{{system.skillSelection.secondary}}"></div>
      </div>

      <label>{{localize "RIFTS.Sheet.OccSkillProgression"}} (JSON Map)</label>
      <textarea rows="8" data-action="class-skill-selection-progression" data-progression-key="occProgression">{{classOccSkillProgressionText}}</textarea>

      <label>{{localize "RIFTS.Sheet.OccRelatedProgression"}} (JSON Map)</label>
      <textarea rows="8" data-action="class-skill-selection-progression" data-progression-key="relatedProgression">{{classRelatedSkillProgressionText}}</textarea>

      <label>{{localize "RIFTS.Sheet.SecondarySkillProgression"}} (JSON Map)</label>
      <textarea rows="8" data-action="class-skill-selection-progression" data-progression-key="secondaryProgression">{{classSecondarySkillProgressionText}}</textarea>

      <label>{{localize "RIFTS.Skills.ClassPackageOcc"}}</label>
      <textarea rows="8" data-action="class-skill-package" data-package-key="occSkills">{{classOccSkillsText}}</textarea>

      <label>{{localize "RIFTS.Skills.ClassPackageRelated"}}</label>
      <textarea rows="8" data-action="class-skill-package" data-package-key="relatedSkills">{{classRelatedSkillsText}}</textarea>

      <label>{{localize "RIFTS.Skills.ClassPackageSecondary"}}</label>
      <textarea rows="8" data-action="class-skill-package" data-package-key="secondarySkills">{{classSecondarySkillsText}}</textarea>
    </section>

    <section class="sheet-section">
      <h2>{{localize "RIFTS.Sheet.Resources"}}</h2>
      <div class="two-col">
        <div><label>{{localize "RIFTS.Sheet.StartingResources"}} (HP)</label><input type="text" name="system.startingResources.hp" value="{{system.startingResources.hp}}"></div>
        <div><label>{{localize "RIFTS.Sheet.StartingResources"}} (SDC)</label><input type="text" name="system.startingResources.sdc" value="{{system.startingResources.sdc}}"></div>
        <div><label>{{localize "RIFTS.Sheet.StartingResources"}} (ISP)</label><input type="text" name="system.startingResources.isp" value="{{system.startingResources.isp}}"></div>
        <div><label>{{localize "RIFTS.Sheet.StartingResources"}} (PPE)</label><input type="text" name="system.startingResources.ppe" value="{{system.startingResources.ppe}}"></div>
      </div>
      <div class="two-col">
        <div><label>{{localize "RIFTS.Sheet.ResourceProgression"}} (HP)</label><input type="text" name="system.resourceProgression.hpPerLevel" value="{{system.resourceProgression.hpPerLevel}}"></div>
